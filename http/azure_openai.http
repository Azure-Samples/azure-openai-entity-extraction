POST https://{{$dotenv AZURE_OPENAI_SERVICE}}.openai.azure.com/openai/v1/responses
Authorization: Bearer {{$dotenv AZURE_OPENAI_TOKEN}}
Content-Type: application/json

{
    "model": "{{$dotenv AZURE_OPENAI_GPT_DEPLOYMENT}}",
    "input": [
        {"role": "system", "content": "Extract the event information."},
        {"role": "user", "content": "Alice and Bob are going to a science fair on Friday."}
    ],
    "text": {
        "format": {
            "type": "json_schema",
            "name": "CalendarEventResponse",
            "strict": true,
            "schema": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "date": {
                        "type": "string"
                    },
                    "participants": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": [
                    "name",
                    "date",
                    "participants"
                ],
                "additionalProperties": false
            }
        }
    },
    "store": false
}
